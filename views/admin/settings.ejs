<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="main-content">
  <div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="h3 mb-0 text-gray-800">
          <i class="bi bi-gear-fill me-2 text-primary"></i>System Settings
        </h2>
        <p class="text-muted mt-1">Configure global parameters for the lab system</p>
      </div>
    </div>
    <div class="row g-4">
      <div class="col-lg-6">
        <div class="card shadow-sm border-0 settings-panel">
          <div class="card-header bg-white border-bottom py-3 d-flex align-items-center gap-3">
            <span class="settings-panel-icon warning"><i class="bi bi-shield-exclamation"></i></span>
            <div>
              <h6 class="m-0 font-weight-bold text-primary">Violation Limitations</h6>
              <small class="text-muted">Control automatic suspension threshold</small>
            </div>
          </div>
          <div class="card-body">
            <form action="/admin/settings" method="POST">
              <div class="mb-4">
                <label for="violation_limit" class="form-label font-weight-bold">
                  Global Violation Limit
                  <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" title="Number of violations before a student is automatically suspended for 15 days."></i>
                </label>
                <div class="input-group">
                  <span class="input-group-text bg-light"><i class="bi bi-exclamation-triangle text-warning"></i></span>
                  <input type="number" class="form-control" id="violation_limit" name="violation_limit" value="<%= violation_limit %>" min="1" required>
                </div>
                <div class="form-text mt-2 text-muted">
                  If a student reaches this limit, their account will be automatically suspended for 15 days. After 15 days, it reactivates and resets the violation count to 0.
                </div>
              </div>
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-save me-1"></i> Save Settings
              </button>
            </form>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="card shadow-sm border-0 settings-panel">
          <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-3">
              <span class="settings-panel-icon teal"><i class="bi bi-building"></i></span>
              <div>
                <h6 class="m-0 font-weight-bold text-primary">Departments</h6>
                <small class="text-muted">Allowed departments for forms and CSV uploads</small>
              </div>
            </div>
            <span class="soft-badge ink"><%= departments.length %> active</span>
          </div>
          <div class="card-body">
            <form action="/admin/settings/departments" method="POST" class="department-add-form mb-3">
              <label for="department" class="form-label font-weight-bold">
                Add Department
                <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" title="CSV rows are accepted only when the department matches this list."></i>
              </label>
              <div class="input-group">
                <span class="input-group-text bg-light"><i class="bi bi-plus-lg text-success"></i></span>
                <input type="text" class="form-control" id="department" name="department" placeholder="e.g. Mathematics" maxlength="80" required>
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-plus-circle me-1"></i>Add
                </button>
              </div>
            </form>

            <div class="department-list" aria-label="Department list">
              <% departments.forEach((department, index) => { %>
                <div class="department-row">
                  <div class="department-row-main">
                    <span class="department-index"><%= index + 1 %></span>
                    <span class="department-name"><%= department %></span>
                  </div>
                  <span class="soft-badge teal">Allowed</span>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Initialize tooltips
  document.addEventListener('DOMContentLoaded', function () {
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
    var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
      return new bootstrap.Tooltip(tooltipTriggerEl)
    })
  });
</script>

<%- include('../partials/footer') %>
