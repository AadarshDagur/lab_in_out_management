<%- include('../partials/header') %>

<h2 class="mb-4"><i class="bi bi-people-fill me-2"></i>Manage Users</h2>

<!-- Add New User Form -->
<div class="card mb-4">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-person-plus me-2"></i>Add New User</h5>
        <button class="btn btn-sm btn-light" type="button" data-bs-toggle="collapse" data-bs-target="#addUserForm">
            <i class="bi bi-chevron-down"></i>
        </button>
    </div>
    <div class="collapse show" id="addUserForm">
        <div class="card-body">
            <form action="/users" method="POST" enctype="multipart/form-data" class="image-upload-form">
                <div class="row">
                    <div class="col-md-2 mb-3">
                        <label class="form-label">Profile Image</label>
                        <div class="user-image-field">
                            <div class="user-avatar-preview user-avatar-preview-lg">
                                <span>+</span>
                                <img src="" alt="Profile preview" class="image-preview d-none">
                            </div>
                            <input type="file" name="profile_image" class="form-control image-upload-input mt-2" accept="image/png,image/jpeg,image/webp,image/gif">
                            <small class="muted-copy">PNG, JPG, WEBP, or GIF</small>
                        </div>
                    </div>
                    <div class="col-md-2 mb-3">
                        <label for="name" class="form-label">Full Name</label>
                        <input type="text" class="form-control" name="name" id="name" placeholder="John Doe" required>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" name="email" id="email" placeholder="user@iitrpr.ac.in" pattern=".+@iitrpr\.ac\.in$" title="Email must end with @iitrpr.ac.in" required>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" class="form-control" name="password" id="password" placeholder="Min 6 chars" required minlength="6">
                    </div>
                    <div class="col-md-3 mb-3">
                        <label for="role" class="form-label">Role</label>
                        <select class="form-select" name="role" id="role" required>
                            <option value="student">Student</option>
                            <option value="assistant">Lab Assistant</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label for="enrollment_no" class="form-label">Enrollment / Staff ID</label>
                        <input type="text" class="form-control" name="enrollment_no" id="enrollment_no" placeholder="e.g. 2023CSB1001" required>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label for="department" class="form-label">Department</label>
                        <select class="form-select" name="department" id="department" required>
                            <option value="">Select</option>
                            <option value="Computer Science">Computer Science</option>
                            <option value="Information Technology">Information Technology</option>
                            <option value="Electronics">Electronics</option>
                            <option value="Electrical">Electrical</option>
                            <option value="Mechanical">Mechanical</option>
                            <option value="Civil">Civil</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label for="phone" class="form-label">Phone</label>
                        <input type="tel" class="form-control" name="phone" id="phone" placeholder="9876543210" required>
                    </div>
                    <div class="col-md-3 mb-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-person-plus me-1"></i>Create User
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Tabs for different roles -->
<ul class="nav nav-tabs mb-3" id="userTabs" role="tablist">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#adminsTab" type="button">
            <i class="bi bi-shield-lock me-1"></i>Admins
            <span class="badge bg-danger ms-1"><%= admins.length %></span>
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#assistantsTab" type="button">
            <i class="bi bi-person-badge me-1"></i>Lab Assistants
            <span class="badge bg-success ms-1"><%= assistants.length %></span>
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#studentsTab" type="button">
            <i class="bi bi-mortarboard me-1"></i>Students
            <span class="badge bg-primary ms-1"><%= students.length %></span>
        </button>
    </li>
</ul>

<div class="tab-content">
    <!-- Admins Tab -->
    <div class="tab-pane fade show active" id="adminsTab">
        <% if (admins.length === 0) { %>
            <p class="text-muted">No admin users found.</p>
        <% } else { %>
            <div class="list-card p-4">
                <div class="filter-group filter-toolbar mb-3">
                    <input type="text" class="form-control" placeholder="Search admins...." data-filter-key="text">
                    <select class="form-select" data-filter-key="status">
                        <option value="">All statuses</option>
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-danger">
                            <tr>
                                <th>Photo</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>ID</th>
                                <th>Department</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody class="filter-targets">
                            <% admins.forEach(user => { %>
                                <tr class="filter-item <%= !user.is_active ? 'table-secondary' : '' %>" data-filter-text="<%= `${user.name} ${user.email} ${user.enrollment_no || ''} ${user.department || ''}`.toLowerCase() %>" data-filter-status="<%= user.is_active ? 'active' : 'inactive' %>">
                                    <td>
                                        <div class="user-avatar-preview user-avatar-preview-sm">
                                            <% if (user.profile_image) { %>
                                                <img src="<%= user.profile_image %>" alt="<%= user.name %>">
                                            <% } else { %>
                                                <span><%= (user.name || 'U').trim().charAt(0).toUpperCase() %></span>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td><%= user.name %></td>
                                    <td><%= user.email %></td>
                                    <td><%= user.enrollment_no || '-' %></td>
                                    <td><%= user.department || '-' %></td>
                                    <td>
                                        <span class="badge bg-<%= user.is_active ? 'success' : 'secondary' %>">
                                            <%= user.is_active ? 'Active' : 'Inactive' %>
                                        </span>
                                    </td>
                                    <td><%= new Date(user.created_at).toLocaleDateString() %></td>
                                    <td>
                                        <% if (user.id !== currentUser.id) { %>
                                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editUser<%= user.id %>">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <form action="/users/<%= user.id %>?_method=DELETE" method="POST" class="d-inline"
                                                  onsubmit="return confirm('Delete this admin?')">
                                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                            </form>
                                        <% } else { %>
                                            <span class="badge bg-info">You</span>
                                        <% } %>
                                    </td>
                                </tr>
                                <%- include('../partials/editUserModal', { user }) %>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>
    </div>

    <!-- Assistants Tab -->
    <div class="tab-pane fade" id="assistantsTab">
        <% if (assistants.length === 0) { %>
            <p class="text-muted">No lab assistants found.</p>
        <% } else { %>
            <div class="list-card p-4">
                <div class="filter-group filter-toolbar mb-3">
                    <input type="text" class="form-control" placeholder="Search assistants...." data-filter-key="text">
                    <select class="form-select" data-filter-key="status">
                        <option value="">All statuses</option>
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-success">
                            <tr>
                                <th>Photo</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Staff ID</th>
                                <th>Department</th>
                                <th>Phone</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody class="filter-targets">
                            <% assistants.forEach(user => { %>
                                <tr class="filter-item <%= !user.is_active ? 'table-secondary' : '' %>" data-filter-text="<%= `${user.name} ${user.email} ${user.enrollment_no || ''} ${user.department || ''} ${user.phone || ''}`.toLowerCase() %>" data-filter-status="<%= user.is_active ? 'active' : 'inactive' %>">
                                    <td>
                                        <div class="user-avatar-preview user-avatar-preview-sm">
                                            <% if (user.profile_image) { %>
                                                <img src="<%= user.profile_image %>" alt="<%= user.name %>">
                                            <% } else { %>
                                                <span><%= (user.name || 'U').trim().charAt(0).toUpperCase() %></span>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td><%= user.name %></td>
                                    <td><%= user.email %></td>
                                    <td><%= user.enrollment_no || '-' %></td>
                                    <td><%= user.department || '-' %></td>
                                    <td><%= user.phone || '-' %></td>
                                    <td>
                                        <span class="badge bg-<%= user.is_active ? 'success' : 'secondary' %>">
                                            <%= user.is_active ? 'Active' : 'Inactive' %>
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editUser<%= user.id %>">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <form action="/users/<%= user.id %>?_method=DELETE" method="POST" class="d-inline"
                                              onsubmit="return confirm('Delete this assistant?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                                <%- include('../partials/editUserModal', { user }) %>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>
    </div>

    <!-- Students Tab -->
    <div class="tab-pane fade" id="studentsTab">
        <% if (students.length === 0) { %>
            <p class="text-muted">No students found.</p>
        <% } else { %>
            <div class="list-card p-4">
                <div class="filter-group filter-toolbar mb-3">
                    <input type="text" class="form-control" placeholder="Search students...." data-filter-key="text">
                    <select class="form-select" data-filter-key="status">
                        <option value="">All statuses</option>
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                        <option value="suspended">Suspended</option>
                    </select>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-primary">
                            <tr>
                                <th>Photo</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Enrollment</th>
                                <th>Department</th>
                                <th>Phone</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody class="filter-targets">
                            <% students.forEach(user => { %>
                                <tr class="filter-item <%= !user.is_active ? 'table-secondary' : '' %>" data-filter-text="<%= `${user.name} ${user.email} ${user.enrollment_no || ''} ${user.department || ''} ${user.phone || ''}`.toLowerCase() %>" data-filter-status="<%= !user.is_active && user.suspended_until ? 'suspended' : (user.is_active ? 'active' : 'inactive') %>">
                                    <td>
                                        <div class="user-avatar-preview user-avatar-preview-sm">
                                            <% if (user.profile_image) { %>
                                                <img src="<%= user.profile_image %>" alt="<%= user.name %>">
                                            <% } else { %>
                                                <span><%= (user.name || 'U').trim().charAt(0).toUpperCase() %></span>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td><%= user.name %></td>
                                    <td><%= user.email %></td>
                                    <td><%= user.enrollment_no || '-' %></td>
                                    <td><%= user.department || '-' %></td>
                                    <td><%= user.phone || '-' %></td>
                                    <td>
                                        <% if (!user.is_active && user.suspended_until) { %>
                                            <span class="badge bg-danger" data-bs-toggle="tooltip" title="Suspended until <%= new Date(user.suspended_until).toLocaleDateString() %>">
                                                Suspended
                                            </span>
                                        <% } else { %>
                                            <span class="badge bg-<%= user.is_active ? 'success' : 'secondary' %>">
                                                <%= user.is_active ? 'Active' : 'Inactive' %>
                                            </span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (!user.is_active && user.suspended_until) { %>
                                            <form action="/users/<%= user.id %>/reactivate" method="POST" class="d-inline" data-confirm="Reactivate this student and reset violation count to 0?" onsubmit="return confirm('Reactivate this student and reset violation count to 0?')">
                                                <button type="submit" class="btn btn-sm btn-outline-success" data-bs-toggle="tooltip" title="Early Reactivate">
                                                    <i class="bi bi-arrow-counterclockwise"></i>
                                                </button>
                                            </form>
                                        <% } %>
                                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editUser<%= user.id %>">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <form action="/users/<%= user.id %>?_method=DELETE" method="POST" class="d-inline"
                                              onsubmit="return confirm('Delete this student?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                                <%- include('../partials/editUserModal', { user }) %>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
