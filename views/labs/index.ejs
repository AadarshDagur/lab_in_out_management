<%- include('../partials/header') %>

<section class="hero-panel mb-4">
    <p class="section-kicker mb-2">Labs</p>
    <h2 class="mb-0">Lab Directory</h2>
</section>

<section class="row g-4" id="labs-directory" data-role="<%= currentUser.activeRole %>">
    <% if (labs.length === 0) { %>
        <div class="col-12">
            <div class="app-card">
                <p class="mb-0 muted-copy">No labs have been created yet.</p>
            </div>
        </div>
    <% } %>
    <% labs.forEach(lab => { %>
        <div class="col-md-6 col-xl-4" data-lab-card="<%= lab.id %>">
            <div class="lab-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h3 class="h4 mb-1"><%= lab.name %></h3>
                        <p class="lab-meta mb-0"><%= lab.location || 'Location not set' %></p>
                    </div>
                    <span data-lab-status-badge>
                        <% if (lab.is_active) { %>
                            <span class="soft-badge <%= Number(lab.current_occupancy) > Number(lab.capacity) ? 'red' : 'teal' %>">
                                <%= lab.current_occupancy %> / <%= lab.capacity %>
                            </span>
                        <% } else { %>
                            <span class="soft-badge ink">Inactive</span>
                        <% } %>
                    </span>
                </div>
                <div data-lab-actions></div>
            </div>
        </div>
    <% }) %>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const directory = document.getElementById('labs-directory');
    if (!directory) return;
    const role = directory.dataset.role;
    const initialLabs = <%- JSON.stringify(labs).replace(/</g, '\\u003c') %>;
    let activeSession = <%- JSON.stringify(activeSession || null).replace(/</g, '\\u003c') %>;
    const labsById = new Map(initialLabs.map((lab) => [String(lab.id), lab]));

    function isActive(value) {
        return value === true || value === 'true' || value === 't' || value === 1 || value === '1';
    }

    function renderCard(lab) {
        const card = directory.querySelector(`[data-lab-card="${lab.id}"]`);
        if (!card) return;
        const active = isActive(lab.is_active);
        const occupancy = Number(lab.current_occupancy || 0);
        const capacity = Number(lab.capacity || 0);
        const badge = card.querySelector('[data-lab-status-badge]');
        const actions = card.querySelector('[data-lab-actions]');
        if (badge) {
            badge.innerHTML = active
                ? `<span class="soft-badge ${occupancy > capacity ? 'red' : 'teal'}">${occupancy} / ${capacity}</span>`
                : '<span class="soft-badge ink">Inactive</span>';
        }
        if (!actions) return;
        if (role === 'student' && activeSession && Number(activeSession.lab_id) === Number(lab.id)) {
            actions.innerHTML = `
                <form action="/sessions/checkout/${activeSession.id}" method="POST" class="mb-2">
                    <button type="submit" class="btn btn-danger w-100 btn-lg"><i class="bi bi-box-arrow-right me-2"></i>Check Out</button>
                </form>`;
        } else if (role === 'student' && !active) {
            actions.innerHTML = '<button type="button" class="btn btn-outline-dark w-100 btn-lg mb-2" disabled>Inactive</button>';
        } else if (role === 'student' && !activeSession) {
            actions.innerHTML = `
                <form action="/sessions/checkin" method="POST" class="mb-2">
                    <input type="hidden" name="lab_id" value="${lab.id}">
                    <button type="submit" class="btn btn-success w-100 btn-lg"><i class="bi bi-box-arrow-in-right me-2"></i>Check In</button>
                </form>`;
        } else if (role === 'assistant' && !active) {
            actions.innerHTML = `
                <form action="/labs/${lab.id}/status" method="POST" class="mb-2 page-refresh-form">
                    <input type="hidden" name="is_active" value="true">
                    <button type="submit" class="btn btn-success w-100 btn-lg"><i class="bi bi-power me-2"></i>Activate Lab</button>
                </form>
                <a href="/labs/${lab.id}" class="btn btn-outline-dark w-100">Open Lab</a>`;
        } else {
            actions.innerHTML = `<a href="/labs/${lab.id}" class="btn btn-outline-dark w-100">Open Lab</a>`;
        }
    }

    function renderAll(labs) {
        labs.forEach((lab) => {
            labsById.set(String(lab.id), lab);
            renderCard(lab);
        });
    }

    async function refreshLabs() {
        try {
            const response = await fetch('/api/labs-state', {
                headers: { Accept: 'application/json' },
                cache: 'no-store',
            });
            if (!response.ok) return;
            const data = await response.json();
            activeSession = data.activeSession || null;
            renderAll(data.labs || []);
        } catch (error) {
            console.warn('Labs refresh failed:', error);
        }
    }

    directory.addEventListener('submit', async function(event) {
        const refreshForm = event.target.closest('.page-refresh-form');
        if (refreshForm) {
            sessionStorage.setItem('labsDirectoryScroll', window.scrollY);
            return; // let form submit naturally
        }
        
        const form = event.target.closest('.live-lab-status-form');
        if (!form) return;
        event.preventDefault();
        try {
            const response = await fetch(form.action, {
                method: 'POST',
                body: new URLSearchParams(new FormData(form)),
                headers: {
                    Accept: 'application/json',
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
            });
            const contentType = response.headers.get('content-type') || '';
            if (!response.ok || !contentType.includes('application/json')) {
                throw new Error('Lab status update did not return JSON');
            }
            await refreshLabs();
        } catch (error) {
            form.submit();
        }
    });

    const runLiveRefresh = () => window.labRunAutoRefresh(refreshLabs);

    renderAll(initialLabs);
    window.labRunAutoRefresh(refreshLabs, { force: true });
    setInterval(runLiveRefresh, 3000);

    // Restore scroll position point
    const savedScroll = sessionStorage.getItem('labsDirectoryScroll');
    if (savedScroll) {
        window.scrollTo(0, parseInt(savedScroll, 10));
        sessionStorage.removeItem('labsDirectoryScroll');
    }
});
</script>

<%- include('../partials/footer') %>
