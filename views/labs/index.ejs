<%- include('../partials/header') %>

<h2 class="mb-4"><i class="bi bi-building me-2"></i>All Labs</h2>

<% if (labs.length === 0) { %>
    <div class="alert alert-info">No labs have been set up yet.</div>
<% } else { %>
    <div class="row">
        <% labs.forEach(lab => { %>
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm <%= lab.available_seats <= 0 ? 'border-danger' : lab.available_seats <= 5 ? 'border-warning' : 'border-success' %>">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><%= lab.name %></h5>
                        <span class="badge <%= lab.available_seats <= 0 ? 'bg-danger' : lab.available_seats <= 5 ? 'bg-warning' : 'bg-success' %>">
                            <%= lab.available_seats %> seats free
                        </span>
                    </div>
                    <div class="card-body">
                        <p><i class="bi bi-geo-alt me-1"></i><%= lab.location || 'N/A' %></p>
                        <p><i class="bi bi-clock me-1"></i><%= lab.open_time %> - <%= lab.close_time %></p>

                        <div class="progress mb-3" style="height: 20px;">
                            <% const pct = lab.capacity > 0 ? Math.round((lab.current_occupancy / lab.capacity) * 100) : 0; %>
                            <div class="progress-bar <%= pct >= 90 ? 'bg-danger' : pct >= 70 ? 'bg-warning' : 'bg-success' %>"
                                 style="width: <%= pct %>%">
                                <%= lab.current_occupancy %>/<%= lab.capacity %>
                            </div>
                        </div>

                        <a href="/labs/<%= lab.id %>" class="btn btn-outline-primary btn-sm w-100">
                            <i class="bi bi-eye me-1"></i>View Details
                        </a>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>

<%- include('../partials/footer') %>
