<%- include('../partials/header') %>

<section class="hero-panel mb-4">
    <p class="section-kicker mb-2">Labs</p>
    <h2 class="mb-0">Lab Directory</h2>
</section>

<section class="row g-4">
    <% if (labs.length === 0) { %>
        <div class="col-12">
            <div class="app-card">
                <p class="mb-0 muted-copy">No labs have been created yet.</p>
            </div>
        </div>
    <% } %>
    <% labs.forEach(lab => { %>
        <% const pct = lab.capacity > 0 ? Math.round((lab.current_occupancy / lab.capacity) * 100) : 0; %>
        <div class="col-md-6 col-xl-4">
            <div class="lab-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h3 class="h4 mb-1"><%= lab.name %></h3>
                        <p class="lab-meta mb-0"><%= lab.location || 'Location not set' %></p>
                    </div>
                    <span class="soft-badge <%= lab.available_seats > 0 ? 'teal' : 'red' %>"><%= lab.available_seats %> free</span>
                </div>
                <div class="occupancy-meter mb-2">
                    <div class="occupancy-fill" style="width: <%= pct %>%"></div>
                </div>
                <p class="muted-copy mb-3"><%= lab.current_occupancy %> of <%= lab.capacity %> occupied</p>
                <a href="/labs/<%= lab.id %>" class="btn btn-outline-dark w-100">Open Lab</a>
            </div>
        </div>
    <% }) %>
</section>

<%- include('../partials/footer') %>
