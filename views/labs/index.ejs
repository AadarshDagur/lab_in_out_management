<%- include('../partials/header') %>

<section class="hero-panel mb-4">
    <p class="section-kicker mb-2">Labs</p>
    <h2 class="mb-0">Lab Directory</h2>
</section>

<section class="row g-4">
    <% if (labs.length === 0) { %>
        <div class="col-12">
            <div class="app-card">
                <p class="mb-0 muted-copy">No labs have been created yet.</p>
            </div>
        </div>
    <% } %>
    <% labs.forEach(lab => { %>
        <div class="col-md-6 col-xl-4">
            <div class="lab-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h3 class="h4 mb-1"><%= lab.name %></h3>
                        <p class="lab-meta mb-0"><%= lab.location || 'Location not set' %></p>
                    </div>
                    <span class="soft-badge <%= Number(lab.current_occupancy) > Number(lab.capacity) ? 'red' : 'teal' %>">
                        <%= lab.current_occupancy %> / <%= lab.capacity %>
                    </span>
                </div>
                <% if (currentUser && currentUser.role === 'student' && !activeSession) { %>
                    <form action="/sessions/checkin" method="POST" class="mb-2">
                        <input type="hidden" name="lab_id" value="<%= lab.id %>">
                        <button type="submit" class="btn btn-success w-100 btn-lg">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Check In
                        </button>
                    </form>
                <% } else if (currentUser && currentUser.role === 'student' && activeSession && Number(activeSession.lab_id) === Number(lab.id)) { %>
                    <form action="/sessions/checkout/<%= activeSession.id %>" method="POST" class="mb-2">
                        <button type="submit" class="btn btn-danger w-100 btn-lg">
                            <i class="bi bi-box-arrow-right me-2"></i>Check Out
                        </button>
                    </form>
                <% } else { %>
                    <a href="/labs/<%= lab.id %>" class="btn btn-outline-dark w-100">Open Lab</a>
                <% } %>
            </div>
        </div>
    <% }) %>
</section>

<%- include('../partials/footer') %>
