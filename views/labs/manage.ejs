<%- include('../partials/header') %>

<section class="hero-panel mb-4">
    <p class="section-kicker mb-2">Lab Setup</p>
    <h2 class="mb-0">Manage Labs</h2>
</section>

<section class="list-card p-4 mb-4">
    <p class="section-kicker mb-1">Add Lab</p>
    <h3 class="mb-3">New lab</h3>
    <form action="/labs" method="POST" class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Lab name</label>
            <input type="text" class="form-control" name="name" placeholder="Computer Lab 1" required>
        </div>
        <div class="col-md-4">
            <label class="form-label">Location</label>
            <input type="text" class="form-control" name="location" placeholder="Block A, Floor 2">
        </div>
        <div class="col-md-4">
            <label class="form-label">Capacity</label>
            <input type="number" class="form-control" name="capacity" value="30" min="1" required>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Create Lab</button>
        </div>
    </form>
</section>

<section class="list-card p-4">
    <p class="section-kicker mb-1">Existing Labs</p>
    <h3 class="mb-3">Manage active labs</h3>
    <% if (labs.length === 0) { %>
        <p class="muted-copy mb-0">No labs yet.</p>
    <% } else { %>
        <div class="table-responsive">
            <table class="table app-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Location</th>
                        <th>Capacity</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="manageLabsRows">
                    <% labs.forEach(lab => { %>
                        <tr>
                            <td><strong><%= lab.name %></strong></td>
                            <td><%= lab.location || '-' %></td>
                            <td><%= lab.capacity %></td>
                            <td><span class="soft-badge <%= lab.is_active ? 'teal' : 'ink' %>"><%= lab.is_active ? 'Active' : 'Inactive' %></span></td>
                            <td class="text-nowrap">
                                <form action="/labs/<%= lab.id %>/status" method="POST" class="d-inline">
                                    <input type="hidden" name="is_active" value="<%= lab.is_active ? 'false' : 'true' %>">
                                    <input type="hidden" name="redirect_to" value="manage">
                                    <button
                                        type="submit"
                                        class="btn btn-outline-<%= lab.is_active ? 'warning' : 'success' %> btn-sm"
                                        onclick="return confirm('<%= lab.is_active ? 'Mark this lab inactive? All currently checked-in students will be checked out without violations.' : 'Reactivate this lab?' %>')"
                                    >
                                        <%= lab.is_active ? 'Mark Inactive' : 'Activate' %>
                                    </button>
                                </form>
                                <button class="btn btn-outline-dark btn-sm" data-bs-toggle="modal" data-bs-target="#editModal<%= lab.id %>">Edit</button>
                                <form action="/labs/<%= lab.id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Delete this lab?')">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                            </td>
                        </tr>

                        <div class="modal fade" id="editModal<%= lab.id %>" tabindex="-1">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Edit <%= lab.name %></h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form action="/labs/<%= lab.id %>?_method=PUT" method="POST">
                                        <div class="modal-body">
                                            <div class="mb-3">
                                                <label class="form-label">Lab name</label>
                                                <input type="text" class="form-control" name="name" value="<%= lab.name %>">
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Location</label>
                                                <input type="text" class="form-control" name="location" value="<%= lab.location || '' %>">
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Capacity</label>
                                                <input type="number" class="form-control" name="capacity" value="<%= lab.capacity %>">
                                            </div>
                                            <div class="mt-3">
                                                <label class="form-label">Status</label>
                                                <select class="form-select" name="is_active">
                                                    <option value="true" <%= lab.is_active ? 'selected' : '' %>>Active</option>
                                                    <option value="false" <%= !lab.is_active ? 'selected' : '' %>>Inactive</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-outline-dark" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary">Save</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const rows = document.getElementById('manageLabsRows');
    if (!rows) return;

    function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"']/g, (char) => ({
            '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'
        })[char]);
    }

    function normalizeBoolean(value) {
        return value === true || value === 'true' || value === 't' || value === 1 || value === '1';
    }

    function renderLabs(labs) {
        if (!labs.length) {
            rows.innerHTML = '<tr><td colspan="5" class="text-muted">No labs yet.</td></tr>';
            return;
        }
        rows.innerHTML = labs.map((lab) => {
            const isActive = normalizeBoolean(lab.is_active);
            const statusText = isActive ? 'Active' : 'Inactive';
            const nextStatus = isActive ? 'false' : 'true';
            const actionText = isActive ? 'Mark Inactive' : 'Activate';
            const actionClass = isActive ? 'warning' : 'success';
            const confirmText = isActive
                ? 'Mark this lab inactive? All currently checked-in students will be checked out without violations.'
                : 'Reactivate this lab?';
            return `
                <tr>
                    <td><strong>${escapeHtml(lab.name)}</strong></td>
                    <td>${escapeHtml(lab.location || '-')}</td>
                    <td>${lab.capacity || 0}</td>
                    <td><span class="soft-badge ${isActive ? 'teal' : 'ink'}">${statusText}</span></td>
                    <td class="text-nowrap">
                        <form action="/labs/${lab.id}/status" method="POST" class="d-inline">
                            <input type="hidden" name="is_active" value="${nextStatus}">
                            <input type="hidden" name="redirect_to" value="manage">
                            <button type="submit" class="btn btn-outline-${actionClass} btn-sm" onclick="return confirm('${confirmText}')">
                                ${actionText}
                            </button>
                        </form>
                        <button class="btn btn-outline-dark btn-sm" data-bs-toggle="modal" data-bs-target="#editModal${lab.id}">Edit</button>
                        <form action="/labs/${lab.id}?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Delete this lab?')">
                            <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                        </form>
                        <div class="modal fade" id="editModal${lab.id}" tabindex="-1">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Edit ${escapeHtml(lab.name)}</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form action="/labs/${lab.id}?_method=PUT" method="POST">
                                        <div class="modal-body">
                                            <div class="mb-3">
                                                <label class="form-label">Lab name</label>
                                                <input type="text" class="form-control" name="name" value="${escapeHtml(lab.name)}">
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Location</label>
                                                <input type="text" class="form-control" name="location" value="${escapeHtml(lab.location || '')}">
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Capacity</label>
                                                <input type="number" class="form-control" name="capacity" value="${lab.capacity || 0}">
                                            </div>
                                            <div class="mt-3">
                                                <label class="form-label">Status</label>
                                                <select class="form-select" name="is_active">
                                                    <option value="true" ${isActive ? 'selected' : ''}>Active</option>
                                                    <option value="false" ${!isActive ? 'selected' : ''}>Inactive</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-outline-dark" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary">Save</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            `;
        }).join('');
    }

    async function refreshLabs() {
        try {
            const response = await fetch('/api/admin/labs', {
                headers: { Accept: 'application/json' },
                cache: 'no-store'
            });
            if (!response.ok) return;
            const data = await response.json();
            renderLabs(data.labs || []);
        } catch (error) {
            console.warn('Manage labs refresh failed:', error);
        }
    }

    document.addEventListener('app:live-update', () => window.labRunAutoRefresh(refreshLabs));
    document.addEventListener('app:app-update', (event) => {
        if (!event.detail || event.detail.type === 'lab' || event.detail.type === 'lab-status') {
            window.labRunAutoRefresh(refreshLabs);
        }
    });
    setInterval(() => window.labRunAutoRefresh(refreshLabs), 3000);
});
</script>

<%- include('../partials/footer') %>
