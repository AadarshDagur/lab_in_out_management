<%- include('../partials/header') %>

<section class="hero-panel mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3">
        <div>
            <p class="section-kicker mb-2">Analytics</p>
            <h2 class="mb-1">Lab Statistics & Export</h2>
            <p class="muted-copy mb-0"><%= periodMeta.label %> (<%= periodMeta.timeLabel %>) capacity usage based on occupied minutes.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <div class="dropdown">
                <button class="btn btn-outline-primary dropdown-toggle" type="button" id="exportBtn" data-bs-toggle="dropdown" aria-expanded="false" style="white-space: nowrap;">
                    <i class="bi bi-cloud-arrow-down-fill me-1"></i> Export As
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="exportBtn">
                    <li><a class="dropdown-item" href="/statistics/export?from=<%= fromDate %>&to=<%= toDate %>&period=<%= selectedPeriod %>&format=csv"><i class="bi bi-filetype-csv me-2 text-success"></i> CSV</a></li>
                    <li><a class="dropdown-item" href="/statistics/export?from=<%= fromDate %>&to=<%= toDate %>&period=<%= selectedPeriod %>&format=excel"><i class="bi bi-file-earmark-excel me-2 text-success"></i> Excel</a></li>
                    <li><a class="dropdown-item" href="/statistics/export?from=<%= fromDate %>&to=<%= toDate %>&period=<%= selectedPeriod %>&format=pdf"><i class="bi bi-file-earmark-pdf me-2 text-danger"></i> PDF</a></li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Date Filter Form -->
<section class="list-card p-3 mb-4 bg-light">
    <form class="row g-3 align-items-end" method="GET" action="/statistics">
        <input type="hidden" name="period" value="<%= selectedPeriod %>">
        <div class="col-md-4">
            <label class="form-label text-muted small fw-bold">From Date</label>
            <input type="date" class="form-control" name="from" id="fromDateInput" value="<%= fromDate %>">
        </div>
        <div class="col-md-4">
            <label class="form-label text-muted small fw-bold">To Date</label>
            <input type="date" class="form-control" name="to" id="toDateInput" value="<%= toDate %>">
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">Apply Date Range</button>
        </div>
    </form>
</section>

<section class="list-card p-3 mb-4">
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-sm <%= selectedPeriod === 'working' ? 'btn-primary' : 'btn-outline-dark' %>" href="/statistics?from=<%= fromDate %>&to=<%= toDate %>&period=working">
            Working Hours
            <span class="ms-1">9 AM - 1 PM, 2 PM - 6 PM</span>
        </a>
        <a class="btn btn-sm <%= selectedPeriod === 'non_working' ? 'btn-primary' : 'btn-outline-dark' %>" href="/statistics?from=<%= fromDate %>&to=<%= toDate %>&period=non_working">
            Non-Working Hours
            <span class="ms-1">6 PM - 9 PM</span>
        </a>
    </div>
</section>

<!-- Lab Capacity Utilization Chart -->
<section class="list-card p-4 mb-4">
    <div class="stats-section-head d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1">Lab Capacity Used</h4>
            <p class="muted-copy mb-0">Occupied minutes divided by available seat-minutes for each lab.</p>
        </div>
    </div>
    <div class="chart-container" style="position: relative; height: 320px; max-width: 760px; margin: 0 auto;">
        <canvas id="labUtilizationChart"></canvas>
    </div>
    <div class="chart-legend-custom mt-3 d-flex justify-content-center flex-wrap gap-3" id="labUtilizationLegend"></div>
    <div class="table-responsive mt-4">
        <table class="table app-table mb-0">
            <thead>
                <tr>
                    <th>Lab</th>
                    <th class="text-center">Capacity</th>
                    <th class="text-center">Open Minutes</th>
                    <th class="text-center">Occupied Minutes</th>
                    <th class="text-center">Available Seat-Minutes</th>
                    <th class="text-center">Used</th>
                </tr>
            </thead>
            <tbody id="labUtilizationRows">
                <% labUtilization.forEach(row => { %>
                    <tr>
                        <td><strong><%= row.lab_name %></strong></td>
                        <td class="text-center"><%= row.capacity %></td>
                        <td class="text-center"><%= row.open_minutes || 0 %></td>
                        <td class="text-center"><%= row.occupied_minutes || 0 %></td>
                        <td class="text-center"><%= row.capacity_minutes || 0 %></td>
                        <td class="text-center">
                            <span class="soft-badge <%= Number(row.utilization_percent || 0) >= 75 ? 'red' : Number(row.utilization_percent || 0) >= 40 ? 'ink' : 'teal' %>">
                                <%= row.utilization_percent || 0 %>%
                            </span>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</section>

<!-- Lab Session Count Chart -->
<section class="list-card p-4 mb-4">
    <div class="stats-section-head d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1">Lab Session Count</h4>
        </div>
    </div>
    <div class="chart-container" style="position: relative; height: 320px; max-width: 760px; margin: 0 auto;">
        <canvas id="labSessionCountChart"></canvas>
    </div>
    <div class="table-responsive mt-4">
        <table class="table app-table mb-0">
            <thead>
                <tr>
                    <th>Lab</th>
                    <th class="text-center">Sessions</th>
                    <th class="text-center">Used</th>
                    <th class="text-center">Occupied Minutes</th>
                </tr>
            </thead>
            <tbody id="labSessionCountRows">
                <% const sessionCountRows = [...labUtilization].sort((a, b) => Number(b.total_sessions || 0) - Number(a.total_sessions || 0)); %>
                <% sessionCountRows.forEach(row => { %>
                    <tr>
                        <td><strong><%= row.lab_name %></strong></td>
                        <td class="text-center"><%= row.total_sessions || 0 %></td>
                        <td class="text-center"><%= row.utilization_percent || 0 %>%</td>
                        <td class="text-center"><%= row.occupied_minutes || 0 %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</section>

<!-- Historical Overfilling Stats -->
<section class="list-card p-4 mb-4">
    <div class="stats-section-head d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">Historical Overfilling Incidents</h4>
        <span class="badge bg-secondary">
            <%= fromDate %> to <%= toDate %>
        </span>
    </div>
    <div class="table-responsive">
        <table class="table app-table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Lab Name</th>
                    <th class="text-center">Capacity Limit</th>
                    <th class="text-center">Overfill Incidents</th>
                    <th class="text-center">Severity</th>
                </tr>
            </thead>
            <tbody id="overfillRows">
                <% if (overfillStats && overfillStats.length > 0) { %>
                    <% overfillStats.forEach(stat => { %>
                        <tr>
                            <td class="fw-bold"><%= stat.lab_name %></td>
                            <td class="text-center text-muted"><%= stat.capacity %> students</td>
                            <td class="text-center">
                                <span class="badge <%= stat.overfill_incidents > 0 ? 'bg-danger' : 'bg-success' %> rounded-pill fs-6 px-3">
                                    <%= stat.overfill_incidents %>
                                </span>
                            </td>
                            <td class="text-center">
                                <% if (stat.overfill_incidents > 10) { %>
                                    <span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i>High</span>
                                <% } else if (stat.overfill_incidents > 0) { %>
                                    <span class="text-warning fw-bold"><i class="bi bi-exclamation-circle-fill me-1"></i>Moderate</span>
                                <% } else { %>
                                    <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Optimal</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">
                            <i class="bi bi-shield-check display-6 d-block mb-2 text-success"></i>
                            No overfilling incidents recorded in this period.
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</section>

<!-- Batch Session Time Chart -->
<section class="list-card p-4 mb-4">
    <div class="stats-section-head d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">Batch Session Time</h4>
        <select class="form-select form-select-sm" id="batchLabSelector" style="width: auto;">
            <% allLabs.forEach(lab => { %>
                <option value="<%= lab.id %>" <%= lab.id === selectedLabId ? 'selected' : '' %>><%= lab.name %><%= lab.is_active ? '' : ' (Inactive)' %></option>
            <% }) %>
        </select>
    </div>
    <div class="chart-container" style="position: relative; height: 320px; max-width: 700px; margin: 0 auto;">
        <canvas id="batchUtilizationChart"></canvas>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
(function() {
    const CHART_COLORS = [
        '#3B82F6', '#93C5FD', '#BFDBFE', '#1E40AF',
        '#60A5FA', '#2563EB', '#DBEAFE', '#1D4ED8',
        '#6366F1', '#818CF8', '#A5B4FC', '#4F46E5'
    ];

    // Lab Utilization
    const labCtx = document.getElementById('labUtilizationChart').getContext('2d');
    const sessionCountCtx = document.getElementById('labSessionCountChart').getContext('2d');
    let labChart = null;
    let sessionCountChart = null;
    const labData = <%- JSON.stringify(labUtilization) %>;
    const selectedPeriod = '<%= selectedPeriod %>';

    function getPercentAxisMax(values) {
        const maxValue = Math.max(...values, 0);
        if (maxValue <= 0) return 10;
        if (maxValue <= 5) return 5;
        if (maxValue <= 10) return 10;
        if (maxValue <= 25) return Math.ceil(maxValue / 5) * 5;
        return Math.min(100, Math.ceil(maxValue / 10) * 10);
    }

    function getCountAxisMax(values) {
        const maxValue = Math.max(...values, 0);
        if (maxValue <= 0) return 5;
        if (maxValue <= 5) return 5;
        if (maxValue <= 10) return 10;
        return Math.ceil(maxValue / 5) * 5;
    }

    function buildLabChart(data) {
        if (labChart) labChart.destroy();

        const labels = data.map(d => d.lab_name);
        const values = data.map(d => Number(d.utilization_percent) || 0);
        const colors = labels.map((_, i) => CHART_COLORS[i % CHART_COLORS.length]);
        const yMax = getPercentAxisMax(values);

        // Build legend
        const legendEl = document.getElementById('labUtilizationLegend');
        legendEl.innerHTML = labels.map((label, i) =>
            `<span class="chart-legend-item"><span class="chart-legend-dot" style="background:${colors[i]}"></span>${label}</span>`
        ).join('');

        labChart = new Chart(labCtx, {
            type: 'bar',
            data: {
                labels,
                datasets: [{
                    label: 'Capacity Used (%)',
                    data: values,
                    backgroundColor: colors,
                    borderRadius: 6,
                    borderSkipped: false,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                const row = data[ctx.dataIndex];
                                return `${ctx.parsed.y}% used (${row.occupied_minutes || 0}/${row.capacity_minutes || 0} seat-min)`;
                            }
                        }
                    },
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        max: yMax,
                        ticks: { callback: value => `${value}%`, font: { family: 'Source Sans 3' } },
                        grid: { color: 'rgba(0,0,0,0.06)' },
                    },
                    x: {
                        ticks: { font: { family: 'Source Sans 3' } },
                        grid: { display: false },
                    }
                }
            }
        });
    }

    function buildSessionCountChart(data) {
        if (sessionCountChart) sessionCountChart.destroy();

        const sortedData = [...data].sort((a, b) => (Number(b.total_sessions) || 0) - (Number(a.total_sessions) || 0));
        const labels = sortedData.map(d => d.lab_name);
        const values = sortedData.map(d => Number(d.total_sessions) || 0);
        const colors = labels.map((_, i) => CHART_COLORS[i % CHART_COLORS.length]);
        const yMax = getCountAxisMax(values);

        sessionCountChart = new Chart(sessionCountCtx, {
            type: 'bar',
            data: {
                labels,
                datasets: [{
                    label: 'Sessions',
                    data: values,
                    backgroundColor: colors,
                    borderRadius: 6,
                    borderSkipped: false,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                const row = sortedData[ctx.dataIndex];
                                return `${ctx.parsed.y} sessions, ${row.utilization_percent || 0}% used`;
                            }
                        }
                    },
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        max: yMax,
                        ticks: {
                            precision: 0,
                            stepSize: yMax <= 10 ? 1 : undefined,
                            font: { family: 'Source Sans 3' },
                        },
                        grid: { color: 'rgba(0,0,0,0.06)' },
                    },
                    x: {
                        ticks: { font: { family: 'Source Sans 3' } },
                        grid: { display: false },
                    }
                }
            }
        });
    }

    buildLabChart(labData);
    buildSessionCountChart(labData);

    // Fetch initialization calls
    function utilizationTone(percent) {
        const value = Number(percent || 0);
        if (value >= 75) return 'red';
        if (value >= 40) return 'ink';
        return 'teal';
    }

    function renderLabTables(data) {
        const utilizationRows = document.getElementById('labUtilizationRows');
        const sessionRows = document.getElementById('labSessionCountRows');
        if (utilizationRows) {
            utilizationRows.innerHTML = data.map(row => `
                <tr>
                    <td><strong>${escapeHtml(row.lab_name)}</strong></td>
                    <td class="text-center">${row.capacity || 0}</td>
                    <td class="text-center">${row.open_minutes || 0}</td>
                    <td class="text-center">${row.occupied_minutes || 0}</td>
                    <td class="text-center">${row.capacity_minutes || 0}</td>
                    <td class="text-center">
                        <span class="soft-badge ${utilizationTone(row.utilization_percent)}">${row.utilization_percent || 0}%</span>
                    </td>
                </tr>
            `).join('');
        }
        if (sessionRows) {
            sessionRows.innerHTML = [...data]
                .sort((a, b) => Number(b.total_sessions || 0) - Number(a.total_sessions || 0))
                .map(row => `
                    <tr>
                        <td><strong>${escapeHtml(row.lab_name)}</strong></td>
                        <td class="text-center">${row.total_sessions || 0}</td>
                        <td class="text-center">${row.utilization_percent || 0}%</td>
                        <td class="text-center">${row.occupied_minutes || 0}</td>
                    </tr>
                `).join('');
        }
    }

    function renderOverfillTable(data) {
        const rows = document.getElementById('overfillRows');
        if (!rows) return;
        if (!data || data.length === 0) {
            rows.innerHTML = `
                <tr>
                    <td colspan="4" class="text-center py-4 text-muted">
                        <i class="bi bi-shield-check display-6 d-block mb-2 text-success"></i>
                        No overfilling incidents recorded in this period.
                    </td>
                </tr>
            `;
            return;
        }
        rows.innerHTML = data.map(stat => {
            const incidents = Number(stat.overfill_incidents || 0);
            const severity = incidents > 10
                ? '<span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i>High</span>'
                : incidents > 0
                    ? '<span class="text-warning fw-bold"><i class="bi bi-exclamation-circle-fill me-1"></i>Moderate</span>'
                    : '<span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Optimal</span>';
            return `
                <tr>
                    <td class="fw-bold">${escapeHtml(stat.lab_name)}</td>
                    <td class="text-center text-muted">${stat.capacity || 0} students</td>
                    <td class="text-center">
                        <span class="badge ${incidents > 0 ? 'bg-danger' : 'bg-success'} rounded-pill fs-6 px-3">${incidents}</span>
                    </td>
                    <td class="text-center">${severity}</td>
                </tr>
            `;
        }).join('');
    }

    function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"']/g, (char) => ({
            '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'
        })[char]);
    }

    async function fetchLabUtilization() {
        const from = document.getElementById('fromDateInput').value;
        const to = document.getElementById('toDateInput').value;
        try {
            const res = await fetch(`/statistics/api/utilization?from=${from}&to=${to}&period=${selectedPeriod}`);
            const data = await res.json();
            buildLabChart(data);
            buildSessionCountChart(data);
            renderLabTables(data);
        } catch(e) {
            console.error('Failed to fetch lab utilization:', e);
        }
    }

    async function fetchOverfillStats() {
        const from = document.getElementById('fromDateInput').value;
        const to = document.getElementById('toDateInput').value;
        try {
            const res = await fetch(`/statistics/api/overfill?from=${from}&to=${to}&period=${selectedPeriod}`);
            const data = await res.json();
            renderOverfillTable(data);
        } catch(e) {
            console.error('Failed to fetch overfill statistics:', e);
        }
    }

    async function refreshStatistics() {
        await Promise.all([fetchLabUtilization(), fetchOverfillStats()]);
        const selector = document.getElementById('batchLabSelector');
        if (selector) {
            selector.dispatchEvent(new Event('change'));
        }
    }

    // Batch Utilization
    const batchCtx = document.getElementById('batchUtilizationChart').getContext('2d');
    let batchChart = null;
    const batchData = <%- JSON.stringify(batchUtilization) %>;

    function buildBatchChart(data) {
        if (batchChart) batchChart.destroy();

        const labels = data.map(d => d.batch);
        const values = data.map(d => parseInt(d.session_minutes) || 0);

        batchChart = new Chart(batchCtx, {
            type: 'bar',
            data: {
                labels,
                datasets: [{
                    label: 'Session Minutes',
                    data: values,
                    backgroundColor: labels.map((_, i) => CHART_COLORS[i % CHART_COLORS.length]),
                    borderRadius: 6,
                    borderSkipped: false,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { font: { family: 'Source Sans 3' } },
                        grid: { color: 'rgba(0,0,0,0.06)' },
                    },
                    x: {
                        ticks: {
                            maxRotation: 45,
                            minRotation: 45,
                            font: { family: 'Source Sans 3', size: 11 }
                        },
                        grid: { display: false },
                    }
                }
            }
        });
    }

    buildBatchChart(batchData);

    document.getElementById('batchLabSelector').addEventListener('change', async function() {
        const from = document.getElementById('fromDateInput').value;
        const to = document.getElementById('toDateInput').value;
        try {
            const res = await fetch(`/statistics/api/batch?lab_id=${this.value}&from=${from}&to=${to}&period=${selectedPeriod}`);
            const data = await res.json();
            buildBatchChart(data);
        } catch(e) {
            console.error('Failed to fetch batch utilization:', e);
        }
    });

})();
</script>

<%- include('../partials/footer') %>
