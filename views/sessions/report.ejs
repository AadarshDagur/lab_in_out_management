<%- include('../partials/header') %>

<h2 class="mb-4"><i class="bi bi-graph-up me-2"></i>Daily Report</h2>

<!-- Date Picker -->
<form class="mb-4" action="/sessions/report" method="GET">
    <div class="row align-items-end">
        <div class="col-md-3">
            <label for="date" class="form-label">Select Date</label>
            <input type="date" class="form-control" name="date" id="date" value="<%= date %>">
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-1"></i>View Report
            </button>
        </div>
    </div>
</form>

<!-- Today's Overview -->
<div class="row mb-4">
    <div class="col-md-4 mb-3">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <h4><%= stats.currently_active || 0 %></h4>
                <p class="mb-0">Currently Active</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h4><%= stats.today_total || 0 %></h4>
                <p class="mb-0">Today's Total Sessions</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <h4><%= stats.avg_duration || 0 %> min</h4>
                <p class="mb-0">Avg Session Duration</p>
            </div>
        </div>
    </div>
</div>

<!-- Lab-wise Report -->
<h4 class="mb-3">Lab-wise Breakdown for <%= date %></h4>
<% if (report.length === 0) { %>
    <p class="text-muted">No sessions recorded for this date.</p>
<% } else { %>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Lab</th>
                    <th>Total Sessions</th>
                    <th>Unique Students</th>
                    <th>Avg Duration (min)</th>
                    <th>Max Duration (min)</th>
                </tr>
            </thead>
            <tbody>
                <% report.forEach(r => { %>
                    <tr>
                        <td><%= r.lab_name %></td>
                        <td><%= r.total_sessions %></td>
                        <td><%= r.unique_students %></td>
                        <td><%= r.avg_duration || 'N/A' %></td>
                        <td><%= r.max_duration ? Math.round(r.max_duration) : 'N/A' %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
<% } %>

<%- include('../partials/footer') %>
