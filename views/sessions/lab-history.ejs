<%- include('../partials/header') %>

<section class="hero-panel mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3">
        <div>
            <p class="section-kicker mb-2">Lab Timeline</p>
            <h2 class="mb-1"><%= lab.name %> History</h2>
            <p class="muted-copy mb-0">Review past sessions recorded in this lab.</p>
        </div>
        <% if (currentUser && (currentUser.activeRole === 'admin' || currentUser.role === 'admin')) { %>
            <a href="/labs/manage" class="btn btn-outline-dark btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Back to Manage Labs
            </a>
        <% } else { %>
            <a href="/labs/<%= lab.id %>" class="btn btn-outline-dark btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Back to Lab
            </a>
        <% } %>
    </div>
</section>

<section class="mb-4">
    <div>
        <div class="list-card p-4">
            <p class="section-kicker mb-1">Session Records</p>
            <h3 class="mb-3">History for <%= lab.name %></h3>
            <div id="lab-full-history-content" data-lab-id="<%= lab.id %>">
            <% if (sessions.length === 0) { %>
                <p class="muted-copy mb-0">No sessions recorded for this lab.</p>
            <% } else { %>
                <div class="filter-group filter-toolbar mb-3">
                    <input type="text" id="labHistorySearchInput" class="form-control" placeholder="Search student or status">
                </div>
                <div class="table-responsive">
                    <table class="table app-table" id="labHistoryTable">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Student</th>
                                <th>Check In</th>
                                <th>Check Out</th>
                                <th>Duration</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% sessions.forEach((s, i) => { %>
                                <tr class="lab-history-row" data-filter-text="<%= [s.user_name, s.enrollment_no || '-', s.status].join(' ').toLowerCase() %>">
                                    <td><%= i + 1 %></td>
                                    <td>
                                        <div class="user-inline">
                                            <div class="user-avatar-preview user-avatar-preview-sm">
                                                <% if (s.profile_image) { %>
                                                    <img src="<%= s.profile_image %>" alt="<%= s.user_name %>">
                                                <% } else { %>
                                                    <span><%= (s.user_name || 'U').trim().charAt(0).toUpperCase() %></span>
                                                <% } %>
                                            </div>
                                            <div>
                                                <strong><%= s.user_name %></strong><br>
                                                <span class="muted-copy"><%= s.enrollment_no || '-' %></span>
                                            </div>
                                        </div>
                                    </td>
                                    <td><%= new Date(s.check_in_time).toLocaleString() %></td>
                                    <td><%= s.check_out_time ? new Date(s.check_out_time).toLocaleString() : '-' %></td>
                                    <td><%= s.duration_minutes ? Math.round(s.duration_minutes) + ' min' : '-' %></td>
                                    <td>
                                        <span class="soft-badge <%= s.status === 'active' ? 'teal' : 'ink' %>">
                                            <%= s.status %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
            </div>
        </div>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const content = document.getElementById('lab-full-history-content');
    if (!content) return;
    const labId = content.dataset.labId;
    const escapeHtml = (value) => String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    const initials = (name) => (name || 'U').trim().charAt(0).toUpperCase() || 'U';
    const avatar = (item) => item.profile_image
        ? `<img src="${escapeHtml(item.profile_image)}" alt="${escapeHtml(item.user_name)}">`
        : `<span>${escapeHtml(initials(item.user_name))}</span>`;

    function applyFilter() {
        const searchInput = document.getElementById('labHistorySearchInput');
        const rows = document.querySelectorAll('#labHistoryTable .lab-history-row');
        if (!searchInput) return;
        const val = searchInput.value.trim().toLowerCase();
        rows.forEach(row => {
            const text = row.dataset.filterText || '';
            row.style.display = text.includes(val) ? '' : 'none';
        });
    }

    function bindSearch() {
        const searchInput = document.getElementById('labHistorySearchInput');
        if (!searchInput || searchInput.dataset.liveBound === 'true') return;
        searchInput.dataset.liveBound = 'true';
        searchInput.addEventListener('input', function() {
            applyFilter();
        });
    }

    function renderHistory(sessions) {
        const currentSearch = document.getElementById('labHistorySearchInput')?.value || '';
        if (!sessions || sessions.length === 0) {
            content.innerHTML = '<p class="muted-copy mb-0">No sessions recorded for this lab.</p>';
            return;
        }
        const rows = sessions.map((session, index) => `
            <tr class="lab-history-row" data-filter-text="${escapeHtml([session.user_name, session.enrollment_no || '-', session.status].join(' ').toLowerCase())}">
                <td>${index + 1}</td>
                <td>
                    <div class="user-inline">
                        <div class="user-avatar-preview user-avatar-preview-sm">${avatar(session)}</div>
                        <div>
                            <strong>${escapeHtml(session.user_name)}</strong><br>
                            <span class="muted-copy">${escapeHtml(session.enrollment_no || '-')}</span>
                        </div>
                    </div>
                </td>
                <td>${new Date(session.check_in_time).toLocaleString()}</td>
                <td>${session.check_out_time ? new Date(session.check_out_time).toLocaleString() : '-'}</td>
                <td>${session.duration_minutes ? `${Math.round(session.duration_minutes)} min` : '-'}</td>
                <td><span class="soft-badge ${session.status === 'active' ? 'teal' : 'ink'}">${escapeHtml(session.status)}</span></td>
            </tr>`).join('');
        content.innerHTML = `
            <div class="filter-group filter-toolbar mb-3">
                <input type="text" id="labHistorySearchInput" class="form-control" placeholder="Search student or status" value="${escapeHtml(currentSearch)}">
            </div>
            <div class="table-responsive">
                <table class="table app-table" id="labHistoryTable">
                    <thead><tr><th>#</th><th>Student</th><th>Check In</th><th>Check Out</th><th>Duration</th><th>Status</th></tr></thead>
                    <tbody>${rows}</tbody>
                </table>
            </div>`;
        bindSearch();
        applyFilter();
    }

    async function refreshHistory() {
        try {
            const response = await fetch(`/api/labs/${labId}/history?limit=100`, {
                headers: { Accept: 'application/json' },
                cache: 'no-store',
            });
            if (!response.ok) return;
            const data = await response.json();
            renderHistory(data.sessions);
        } catch (error) {
            console.warn('Lab history refresh failed:', error);
        }
    }

    bindSearch();
    refreshHistory();
    setInterval(() => window.labRunAutoRefresh(refreshHistory), 3000);
});
</script>
<%- include('../partials/footer') %>
