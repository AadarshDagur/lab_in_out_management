<%- include('../partials/header') %>

<section class="hero-panel mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3">
        <div>
            <p class="section-kicker mb-2">Student Profile</p>
            <div class="d-flex align-items-center gap-3">
                <div class="user-avatar-preview user-avatar-preview-lg">
                    <% if (student.profile_image) { %>
                        <img src="<%= student.profile_image %>" alt="<%= student.name %>">
                    <% } else { %>
                        <span><%= (student.name || 'U').trim().charAt(0).toUpperCase() %></span>
                    <% } %>
                </div>
                <div>
                    <h2 class="mb-1"><%= student.name %></h2>
                    <p class="muted-copy mb-0"><%= student.enrollment_no || 'No Enrollment ID' %> • <%= student.department || 'No Department' %></p>
                </div>
            </div>
        </div>
        <div class="d-flex flex-column align-items-end gap-2">
            <div class="d-flex gap-2 flex-wrap justify-content-end">
                <div class="dropdown">
                    <button class="btn btn-outline-dark btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-download me-1"></i>Export History
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/sessions/student/<%= student.id %>/export?format=csv">Download CSV</a></li>
                        <li><a class="dropdown-item" href="/sessions/student/<%= student.id %>/export?format=excel">Download Excel</a></li>
                        <li><a class="dropdown-item" href="/sessions/student/<%= student.id %>/export?format=pdf">Download PDF</a></li>
                    </ul>
                </div>
                <a href="<%= (currentUser.activeRole || currentUser.role) === 'admin' ? '/admin/directory' : '/dashboard?section=directory' %>" class="btn btn-outline-dark btn-sm">
                    <i class="bi bi-arrow-left me-1"></i>Back to Directory
                </a>
            </div>
            <% if (student.suspended_until && new Date(student.suspended_until) > new Date()) { %>
                <span class="soft-badge red">Suspended until <%= new Date(student.suspended_until).toLocaleDateString() %></span>
            <% } else if (student.is_active) { %>
                <span class="soft-badge teal">Active Status</span>
            <% } else { %>
                <span class="soft-badge ink">Inactive Account</span>
            <% } %>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-12">
        <section class="list-card p-4 h-100">
            <p class="section-kicker mb-1">Session Records</p>
            <h3 class="mb-3">Recent Lab History</h3>
            <div id="student-detail-history-content" data-student-id="<%= student.id %>">
            <% if (sessions.length === 0) { %>
                <p class="muted-copy mb-0">No lab sessions recorded yet.</p>
            <% } else { %>
                <div class="table-responsive bounded-history-table">
                    <table class="table app-table">
                        <thead>
                            <tr>
                                <th>Lab</th>
                                <th>Check In</th>
                                <th>Check Out</th>
                                <th>Duration</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% sessions.forEach(s => { %>
                                <tr>
                                    <td><%= s.lab_name %></td>
                                    <td><%= new Date(s.check_in_time).toLocaleString() %></td>
                                    <td><%= s.check_out_time ? new Date(s.check_out_time).toLocaleString() : '-' %></td>
                                    <td><%= s.duration_minutes ? Math.round(s.duration_minutes) + ' min' : '-' %></td>
                                    <td>
                                        <span class="soft-badge <%= s.status === 'active' ? 'teal' : 'ink' %>">
                                            <%= s.status %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
            </div>
        </section>
    </div>
    
    <div class="col-12">
        <section class="list-card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <p class="section-kicker mb-1">Conduct</p>
                    <h3 class="mb-0">Violations</h3>
                </div>
                <span class="soft-badge <%= student.violation_count > 0 ? 'red' : 'teal' %>">
                    Count: <%= student.violation_count || 0 %>
                </span>
            </div>
            
            <% if (violations.length === 0) { %>
                <div class="p-3 bg-light rounded text-center">
                    <i class="bi bi-shield-check text-success fs-2 mb-2 d-block"></i>
                    <p class="muted-copy mb-0">Clean record. No violations found.</p>
                </div>
            <% } else { %>
                <div class="table-responsive bounded-violations-list">
                    <table class="table app-table align-middle">
                        <thead>
                            <tr>
                                <th>Lab</th>
                                <th>Note</th>
                                <th>Marked By</th>
                                <th>Date & Time</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% violations.forEach(item => { %>
                                <tr>
                                    <td><strong><%= item.lab_name %></strong></td>
                                    <td class="text-break" style="max-width: 250px;"><%= item.note || 'No note provided' %></td>
                                    <td><%= item.marked_by_name || 'System' %></td>
                                    <td class="text-nowrap">
                                        <%= new Date(item.created_at).toLocaleDateString() %><br>
                                        <span class="muted-copy"><%= new Date(item.created_at).toLocaleTimeString() %></span>
                                    </td>
                                    <td class="text-end">
                                        <% if (!item.locked) { %>
                                            <% if (currentUser.activeRole === 'admin' || currentUser.role === 'admin') { %>
                                                <form action="/sessions/remove-violation/<%= item.id %>" method="POST" class="d-inline remove-violation-form">
                                                    <button type="button" class="btn btn-outline-danger btn-sm remove-violation-btn">Remove</button>
                                                </form>
                                            <% } else if (currentUser.activeRole === 'assistant' || currentUser.activeRole === 'student+assistant') { %>
                                                <% if (item.removal_request_status === 'pending') { %>
                                                    <button type="button" class="btn btn-outline-secondary btn-sm" disabled>Request Submitted</button>
                                                <% } else if (item.removal_request_status === 'rejected') { %>
                                                    <button type="button" class="btn btn-outline-danger btn-sm" disabled>Removal Denied</button>
                                                <% } else { %>
                                                    <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#requestRemovalModal" data-violation-id="<%= item.id %>" data-student-name="<%= student.name %>">
                                                        Request Removal
                                                    </button>
                                                <% } %>
                                            <% } %>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>
    </div>
</div>

<div class="modal fade" id="requestRemovalModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold">Request Violation Removal</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="" method="POST" id="requestRemovalForm">
          <div class="modal-body py-4">
            <p>You are requesting the admin to remove a violation for <strong id="removalStudentName"></strong>.</p>
            <div class="mb-3">
                <label class="form-label text-muted">Reason for removal</label>
                <textarea class="form-control bg-light border-0" name="reason" rows="3" required placeholder="Explain why this violation was a mistake or should be forgiven..."></textarea>
            </div>
          </div>
          <div class="modal-footer border-0">
            <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary px-4">Submit Request</button>
          </div>
      </form>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const requestModal = document.getElementById('requestRemovalModal');
    if (requestModal) {
        requestModal.addEventListener('show.bs.modal', function(event) {
            const button = event.relatedTarget;
            const violationId = button.getAttribute('data-violation-id');
            const studentName = button.getAttribute('data-student-name');

            document.getElementById('removalStudentName').textContent = studentName;
            document.getElementById('requestRemovalForm').action = `/sessions/request-violation-removal/${violationId}`;
        });
    }

    // Handle remove violation buttons with SweetAlert2
    document.querySelectorAll('.remove-violation-btn').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            const form = btn.closest('form');
            if (!form) return;

            Swal.fire({
                title: 'Are you sure?',
                text: 'Remove this violation?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#1f4f8f',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, remove it!'
            }).then(function(result) {
                if (result.isConfirmed) {
                    HTMLFormElement.prototype.submit.call(form);
                }
            });
        });
    });

    const historyContent = document.getElementById('student-detail-history-content');
    const escapeHtml = (value) => String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

    function renderStudentHistory(sessions) {
        if (!historyContent) return;
        if (!sessions || sessions.length === 0) {
            historyContent.innerHTML = '<p class="muted-copy mb-0">No lab sessions recorded yet.</p>';
            return;
        }
        const rows = sessions.map((session) => `
            <tr>
                <td>${escapeHtml(session.lab_name)}</td>
                <td>${new Date(session.check_in_time).toLocaleString()}</td>
                <td>${session.check_out_time ? new Date(session.check_out_time).toLocaleString() : '-'}</td>
                <td>${session.duration_minutes ? `${Math.round(session.duration_minutes)} min` : '-'}</td>
                <td><span class="soft-badge ${session.status === 'active' ? 'teal' : 'ink'}">${escapeHtml(session.status)}</span></td>
            </tr>`).join('');
        historyContent.innerHTML = `
            <div class="table-responsive bounded-history-table">
                <table class="table app-table">
                    <thead><tr><th>Lab</th><th>Check In</th><th>Check Out</th><th>Duration</th><th>Status</th></tr></thead>
                    <tbody>${rows}</tbody>
                </table>
            </div>`;
    }

    async function refreshStudentHistory() {
        if (!historyContent) return;
        try {
            const studentId = historyContent.dataset.studentId;
            const response = await fetch(`/api/students/${studentId}/history?limit=50`, {
                headers: { Accept: 'application/json' },
                cache: 'no-store',
            });
            if (!response.ok) return;
            const data = await response.json();
            renderStudentHistory(data.sessions);
        } catch (error) {
            console.warn('Student detail history refresh failed:', error);
        }
    }

    refreshStudentHistory();
    setInterval(() => window.labRunAutoRefresh(refreshStudentHistory), 3000);
});
</script>

<%- include('../partials/footer') %>
