<%- include('../partials/header') %>

<h2 class="mb-4"><i class="bi bi-speedometer2 me-2"></i>Assistant Dashboard</h2>

<!-- Today's Stats -->
<div class="row mb-4">
    <div class="col-md-4 mb-3">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <i class="bi bi-people display-6"></i>
                <h3 class="mt-2"><%= stats.currently_active || 0 %></h3>
                <p class="mb-0">Currently Active</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <i class="bi bi-check-circle display-6"></i>
                <h3 class="mt-2"><%= stats.today_total || 0 %></h3>
                <p class="mb-0">Today's Total</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <i class="bi bi-clock display-6"></i>
                <h3 class="mt-2"><%= stats.avg_duration || 0 %> min</h3>
                <p class="mb-0">Avg Duration</p>
            </div>
        </div>
    </div>
</div>

<!-- Lab Occupancy -->
<h4><i class="bi bi-building me-2"></i>Lab Occupancy</h4>
<div class="row mb-4">
    <% labs.forEach(lab => { %>
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5><%= lab.name %></h5>
                    <p class="text-muted mb-2"><%= lab.location || '' %></p>
                    <div class="progress mb-2" style="height: 25px;">
                        <% const pct = lab.capacity > 0 ? Math.round((lab.current_occupancy / lab.capacity) * 100) : 0; %>
                        <div class="progress-bar <%= pct >= 90 ? 'bg-danger' : pct >= 70 ? 'bg-warning' : 'bg-success' %>"
                             style="width: <%= pct %>%">
                            <%= lab.current_occupancy %>/<%= lab.capacity %>
                        </div>
                    </div>
                    <a href="/labs/<%= lab.id %>" class="btn btn-outline-primary btn-sm">View Details</a>
                    <a href="/qr/setup/<%= lab.id %>" class="btn btn-dark btn-sm"><i class="bi bi-qr-code me-1"></i>QR</a>
                    <a href="/sessions/lab/<%= lab.id %>" class="btn btn-outline-secondary btn-sm">History</a>
                </div>
            </div>
        </div>
    <% }) %>
</div>

<!-- Active Sessions -->
<h4><i class="bi bi-people me-2"></i>Currently Active Students</h4>
<% if (activeSessions.length === 0) { %>
    <p class="text-muted">No active sessions at the moment.</p>
<% } else { %>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Student</th>
                    <th>Enrollment</th>
                    <th>Lab</th>
                    <th>Seat</th>
                    <th>Check In</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% activeSessions.forEach(s => { %>
                    <tr>
                        <td><%= s.user_name %></td>
                        <td><%= s.enrollment_no %></td>
                        <td><%= s.lab_name %></td>
                        <td><%= s.seat_number || '-' %></td>
                        <td><%= new Date(s.check_in_time).toLocaleTimeString() %></td>
                        <td>
                            <form action="/sessions/checkout/<%= s.id %>" method="POST" class="d-inline">
                                <button type="submit" class="btn btn-danger btn-sm">
                                    <i class="bi bi-box-arrow-right me-1"></i>Check Out
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
<% } %>

<%- include('../partials/footer') %>
