<%- include('../partials/header') %>

<section class="hero-panel mb-4">
    <div class="row g-4 align-items-start">
        <div class="col-lg-8">
            <p class="section-kicker mb-2">Assistant Console</p>
            <h2 class="mb-3">Dashboard</h2>
        </div>
        <div class="col-lg-4">
            <div class="row g-3">
                <div class="col-12">
                    <div class="stat-tile orange">
                        <small>Currently Active</small>
                        <h3><%= stats.currently_active || 0 %></h3>
                    </div>
                </div>
                <div class="col-6">
                    <div class="stat-tile teal">
                        <small>Today Total</small>
                        <h3><%= stats.today_total || 0 %></h3>
                    </div>
                </div>
                <div class="col-6">
                    <div class="stat-tile ink">
                        <small>Avg Duration</small>
                        <h3><%= stats.avg_duration || 0 %></h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<% if (activeSection === 'live') { %>
<section class="list-card p-4">
    <% if (activeSessions.length === 0) { %>
        <p class="muted-copy mb-0">No active sessions right now.</p>
    <% } else { %>
        <div class="filter-group filter-toolbar mb-3">
            <input type="text" class="form-control" placeholder="Search student or lab" data-filter-key="text">
            <select class="form-select" data-filter-key="lab">
                <option value="">All labs</option>
                <% labs.forEach(lab => { %>
                    <option value="<%= lab.name %>"><%= lab.name %></option>
                <% }) %>
            </select>
        </div>
        <div class="table-responsive">
            <table class="table app-table">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Lab</th>
                        <th>Seat</th>
                        <th>Since</th>
                        <th>Duration</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody class="filter-targets">
                    <% activeSessions.forEach(session => { %>
                        <% const minutes = Math.max(1, Math.round((Date.now() - new Date(session.check_in_time).getTime()) / 60000)); %>
                        <tr class="filter-item" data-filter-text="<%= `${session.user_name} ${session.enrollment_no || ''} ${session.lab_name}`.toLowerCase() %>" data-filter-lab="<%= session.lab_name %>">
                            <td>
                                <strong><%= session.user_name %></strong><br>
                                <span class="muted-copy"><%= session.enrollment_no %></span>
                            </td>
                            <td><%= session.lab_name %></td>
                            <td><span class="soft-badge orange"><%= session.seat_number || 'Unassigned' %></span></td>
                            <td><%= new Date(session.check_in_time).toLocaleTimeString() %></td>
                            <td><span class="soft-badge ink duration-pill"><%= minutes %> min</span></td>
                            <td>
                                <form action="/sessions/checkout/<%= session.id %>" method="POST">
                                    <button type="submit" class="btn btn-sm btn-danger">Check Out</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</section>
<% } %>

<% if (activeSection === 'violations') { %>
<section class="list-card p-4">
    <% if (recentViolations.length === 0) { %>
        <p class="muted-copy mb-0">No violation cases yet.</p>
    <% } else { %>
        <div class="filter-group filter-toolbar mb-3">
            <input type="text" class="form-control" placeholder="Search student or lab" data-filter-key="text">
            <select class="form-select" data-filter-key="lab">
                <option value="">All labs</option>
                <% labs.forEach(lab => { %>
                    <option value="<%= lab.name %>"><%= lab.name %></option>
                <% }) %>
            </select>
        </div>
        <div class="d-grid gap-3 filter-targets">
            <% recentViolations.forEach(item => { %>
                <div class="glass-panel filter-item" data-filter-text="<%= `${item.user_name} ${item.enrollment_no || ''} ${item.lab_name} ${item.note || ''}`.toLowerCase() %>" data-filter-lab="<%= item.lab_name %>">
                    <div class="d-flex justify-content-between gap-3">
                        <div>
                            <strong><%= item.user_name %></strong>
                            <div class="muted-copy"><%= item.lab_name %> | <%= item.enrollment_no %></div>
                            <% if (item.note) { %><div class="muted-copy"><%= item.note %></div><% } %>
                        </div>
                        <div class="text-end">
                            <div class="soft-badge red">Count: <%= item.violation_count %></div>
                            <div class="muted-copy mt-2"><%= new Date(item.created_at).toLocaleString() %></div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</section>
<% } %>

<% if (activeSection === 'directory') { %>
<section class="row g-4">
    <div class="col-lg-5">
        <div class="list-card p-4 h-100">
            <p class="section-kicker mb-1">Labs</p>
            <h3 class="mb-3">Occupancy overview</h3>
            <div class="filter-group filter-toolbar mb-3">
                <input type="text" class="form-control" placeholder="Search lab" data-filter-key="text">
                <select class="form-select" data-filter-key="availability">
                    <option value="">All</option>
                    <option value="available">Available</option>
                    <option value="full">Full</option>
                </select>
            </div>
            <div class="d-grid gap-3 filter-targets">
                <% labs.forEach(lab => { %>
                    <% const pct = lab.capacity > 0 ? Math.round((lab.current_occupancy / lab.capacity) * 100) : 0; %>
                    <div class="glass-panel filter-item" data-filter-text="<%= `${lab.name} ${lab.location || ''}`.toLowerCase() %>" data-filter-availability="<%= lab.available_seats > 0 ? 'available' : 'full' %>">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <strong><%= lab.name %></strong>
                                <div class="muted-copy"><%= lab.location || 'Location not set' %></div>
                            </div>
                            <span class="soft-badge <%= lab.available_seats > 0 ? 'teal' : 'red' %>"><%= lab.current_occupancy %>/<%= lab.capacity %></span>
                        </div>
                        <div class="occupancy-meter mb-3">
                            <div class="occupancy-fill" style="width: <%= pct %>%"></div>
                        </div>
                        <a href="/labs/<%= lab.id %>" class="btn btn-outline-dark btn-sm w-100">Open Lab</a>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="list-card p-4 h-100">
            <p class="section-kicker mb-1">Students</p>
            <h3 class="mb-3">Student directory</h3>
            <div class="filter-group filter-toolbar mb-3">
                <input type="text" class="form-control" placeholder="Search student" data-filter-key="text">
                <select class="form-select" data-filter-key="violation">
                    <option value="">All</option>
                    <option value="flagged">With violations</option>
                    <option value="clear">No violations</option>
                </select>
            </div>
            <div class="table-responsive">
                <table class="table app-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Enrollment</th>
                            <th>Department</th>
                            <th>Violation Count</th>
                        </tr>
                    </thead>
                    <tbody class="filter-targets">
                        <% students.slice(0, 12).forEach(student => { %>
                            <tr class="filter-item" data-filter-text="<%= `${student.name} ${student.enrollment_no || ''} ${student.department || ''}`.toLowerCase() %>" data-filter-violation="<%= student.violation_count > 0 ? 'flagged' : 'clear' %>">
                                <td><%= student.name %></td>
                                <td><%= student.enrollment_no || '-' %></td>
                                <td><%= student.department || '-' %></td>
                                <td><span class="soft-badge <%= student.violation_count > 0 ? 'red' : 'ink' %>"><%= student.violation_count || 0 %></span></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
<% } %>

<%- include('../partials/footer') %>
