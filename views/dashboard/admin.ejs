<%- include('../partials/header') %>

<section class="hero-panel mb-4">
    <div class="row g-4 align-items-start">
        <div class="col-lg-8">
            <p class="section-kicker mb-2">Administrator Panel</p>
            <h2 class="mb-3">System Control</h2>
            <p class="muted-copy mb-3">Admins manage labs, user accounts, and system settings. Daily lab operations stay with assistants and students.</p>
            <div class="d-flex flex-wrap gap-3">
                <a href="/labs/manage" class="btn btn-primary">Manage Labs</a>
                <a href="/users" class="btn btn-outline-dark">Manage Users</a>
                <a href="/admin/settings" class="btn btn-outline-dark">System Settings</a>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="row g-3">
                <div class="col-6">
                    <div class="stat-tile ink">
                        <small>Total Labs</small>
                        <h3><%= labCount %></h3>
                    </div>
                </div>
                <div class="col-6">
                    <div class="stat-tile teal">
                        <small>Today Total</small>
                        <h3><%= stats.today_total || 0 %></h3>
                    </div>
                </div>
                <div class="col-6">
                    <div class="stat-tile orange">
                        <small>Active Now</small>
                        <h3><%= stats.currently_active || 0 %></h3>
                    </div>
                </div>
                <div class="col-6">
                    <div class="stat-tile ink">
                        <small>Students</small>
                        <h3><%= studentCount %></h3>
                    </div>
                </div>
                <div class="col-6">
                    <div class="stat-tile red">
                        <small>Assistants</small>
                        <h3><%= assistantCount %></h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="list-card p-4">
    <p class="section-kicker mb-1">Admin Scope</p>
    <h3 class="mb-3">What admins handle</h3>
    <div class="row g-3">
        <div class="col-md-4">
            <div class="glass-panel h-100">
                <h4 class="h6 mb-2">Users</h4>
                <p class="muted-copy mb-0">Create accounts, update roles, suspend or reactivate users, and maintain profiles.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-panel h-100">
                <h4 class="h6 mb-2">Labs</h4>
                <p class="muted-copy mb-0">Create labs, change capacities and timings, and activate or deactivate labs.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-panel h-100">
                <h4 class="h6 mb-2">Settings</h4>
                <p class="muted-copy mb-0">Configure global rules like the violation limit used by the system.</p>
            </div>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
