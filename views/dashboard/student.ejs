<%- include('../partials/header') %>

<h2 class="mb-4"><i class="bi bi-speedometer2 me-2"></i>Student Dashboard</h2>

<!-- Active Session Alert -->
<% if (activeSession) { %>
    <div class="alert alert-info d-flex justify-content-between align-items-center">
        <div>
            <i class="bi bi-info-circle-fill me-2"></i>
            <strong>Currently checked in:</strong> <%= activeSession.lab_name %>
            <% if (activeSession.seat_number) { %> | Seat: <%= activeSession.seat_number %><% } %>
            | Since: <%= new Date(activeSession.check_in_time).toLocaleTimeString() %>
        </div>
        <form action="/sessions/checkout/<%= activeSession.id %>" method="POST">
            <button type="submit" class="btn btn-danger btn-sm">
                <i class="bi bi-box-arrow-right me-1"></i>Check Out
            </button>
        </form>
    </div>
<% } %>

<!-- Available Labs -->
<div class="row mb-4">
    <div class="col-12">
        <h4><i class="bi bi-building me-2"></i>Available Labs</h4>
    </div>
    <% if (labs.length === 0) { %>
        <div class="col-12">
            <p class="text-muted">No labs available at the moment.</p>
        </div>
    <% } %>
    <% labs.forEach(lab => { %>
        <div class="col-md-4 mb-3">
            <div class="card h-100 <%= lab.available_seats <= 0 ? 'border-danger' : lab.available_seats <= 5 ? 'border-warning' : 'border-success' %>">
                <div class="card-body">
                    <h5 class="card-title"><%= lab.name %></h5>
                    <p class="text-muted mb-2"><i class="bi bi-geo-alt me-1"></i><%= lab.location || 'N/A' %></p>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>
                            <i class="bi bi-people me-1"></i>
                            <%= lab.current_occupancy %>/<%= lab.capacity %>
                        </span>
                        <span class="badge <%= lab.available_seats <= 0 ? 'bg-danger' : lab.available_seats <= 5 ? 'bg-warning' : 'bg-success' %>">
                            <%= lab.available_seats %> available
                        </span>
                    </div>

                    <% if (lab.available_seats <= 0) { %>
                        <span class="badge bg-danger w-100 mt-2 py-2">Full</span>
                    <% } %>
                </div>
            </div>
        </div>
    <% }) %>
</div>

<!-- QR Scan Button -->
<% if (!activeSession) { %>
<div class="row mb-4">
    <div class="col-12 text-center">
        <a href="/qr/scan" class="btn btn-info btn-lg">
            <i class="bi bi-qr-code-scan me-2"></i>Scan QR Code to Check In
        </a>
        <p class="text-muted mt-2">Scan the QR code displayed on the lab screen to check in</p>
    </div>
</div>
<% } %>

<!-- Recent History -->
<div class="row">
    <div class="col-12">
        <h4><i class="bi bi-clock-history me-2"></i>Recent Activity</h4>
        <% if (recentHistory.length === 0) { %>
            <p class="text-muted">No lab visits yet.</p>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Lab</th>
                            <th>Seat</th>
                            <th>Check In</th>
                            <th>Check Out</th>
                            <th>Duration</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentHistory.forEach(s => { %>
                            <tr>
                                <td><%= s.lab_name %></td>
                                <td><%= s.seat_number || '-' %></td>
                                <td><%= new Date(s.check_in_time).toLocaleString() %></td>
                                <td><%= s.check_out_time ? new Date(s.check_out_time).toLocaleString() : '-' %></td>
                                <td><%= s.duration_minutes ? Math.round(s.duration_minutes) + ' min' : '-' %></td>
                                <td>
                                    <span class="badge bg-<%= s.status === 'active' ? 'success' : s.status === 'completed' ? 'secondary' : 'warning' %>">
                                        <%= s.status %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
