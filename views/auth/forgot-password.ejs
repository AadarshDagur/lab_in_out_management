<%- include('../partials/header') %>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <span class="display-5 text-primary"><i class="bi bi-key"></i></span>
                    <h4 class="mt-2">Forgot Password?</h4>
                    <p class="text-muted">Enter your email address and we'll send you a link to reset your password.</p>
                </div>

                <form action="/auth/forgot-password" method="POST">
                    <div class="mb-3">
                        <label for="email" class="form-label">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input type="email" class="form-control" id="email" name="email"
                                   placeholder="you@iitrpr.ac.in" required autofocus
                                   pattern=".+@iitrpr\.ac\.in$" title="Email must end with @iitrpr.ac.in">
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mb-3">
                        <i class="bi bi-send me-1"></i>Send Reset Link
                    </button>
                </form>

                <div class="text-center">
                    <a href="/auth/login" class="text-muted">
                        <i class="bi bi-arrow-left me-1"></i>Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
