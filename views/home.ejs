<%- include('partials/header') %>

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold text-primary">
        <i class="bi bi-pc-display-horizontal me-3"></i>Lab In/Out Management
    </h1>
    <p class="lead text-muted mt-3">
        Track and manage computer lab entry and exit for students and lab assistants.
    </p>

    <!-- 3 Stakeholder Roles -->
    <h4 class="mt-5 mb-3 text-secondary">Three Roles, One Platform</h4>
    <div class="row justify-content-center">
        <div class="col-md-4 mb-3">
            <div class="card border-primary h-100">
                <div class="card-header bg-primary text-white text-center">
                    <i class="bi bi-mortarboard me-1"></i> Student
                </div>
                <div class="card-body text-center">
                    <i class="bi bi-mortarboard display-4 text-primary"></i>
                    <ul class="list-unstyled mt-3 text-start">
                        <li><i class="bi bi-check-circle text-success me-1"></i> Quick check-in / check-out</li>
                        <li><i class="bi bi-check-circle text-success me-1"></i> View lab availability</li>
                        <li><i class="bi bi-check-circle text-success me-1"></i> Personal usage history</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-success h-100">
                <div class="card-header bg-success text-white text-center">
                    <i class="bi bi-person-badge me-1"></i> Lab Assistant
                </div>
                <div class="card-body text-center">
                    <i class="bi bi-person-badge display-4 text-success"></i>
                    <ul class="list-unstyled mt-3 text-start">
                        <li><i class="bi bi-check-circle text-success me-1"></i> Manage student check-ins</li>
                        <li><i class="bi bi-check-circle text-success me-1"></i> Monitor lab occupancy</li>
                        <li><i class="bi bi-check-circle text-success me-1"></i> View lab session history</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-danger h-100">
                <div class="card-header bg-danger text-white text-center">
                    <i class="bi bi-shield-lock me-1"></i> Admin
                </div>
                <div class="card-body text-center">
                    <i class="bi bi-shield-lock display-4 text-danger"></i>
                    <ul class="list-unstyled mt-3 text-start">
                        <li><i class="bi bi-check-circle text-success me-1"></i> Create & manage labs</li>
                        <li><i class="bi bi-check-circle text-success me-1"></i> Manage assistants & students</li>
                        <li><i class="bi bi-check-circle text-success me-1"></i> View reports & analytics</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="/auth/login" class="btn btn-primary btn-lg">
            <i class="bi bi-box-arrow-in-right me-1"></i>Login
        </a>
    </div>
    <p class="text-muted mt-3"><small>All user accounts are created by the administrator.</small></p>
</div>

<%- include('partials/footer') %>
