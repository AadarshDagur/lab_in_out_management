<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
        <a class="navbar-brand" href="/">
            <i class="bi bi-pc-display-horizontal me-2"></i>Lab Manager
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">
                            <i class="bi bi-speedometer2 me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/labs">
                            <i class="bi bi-building me-1"></i>Labs
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/sessions/history">
                            <i class="bi bi-clock-history me-1"></i>History
                        </a>
                    </li>
                    <% if (currentUser.role === 'student') { %>
                        <li class="nav-item">
                            <a class="nav-link text-warning" href="/qr/scan">
                                <i class="bi bi-qr-code-scan me-1"></i>Scan QR
                            </a>
                        </li>
                    <% } %>
                    <% if (currentUser.role === 'admin' || currentUser.role === 'assistant') { %>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-warning" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-qr-code me-1"></i>Show QR
                            </a>
                            <ul class="dropdown-menu">
                                <li><h6 class="dropdown-header">Select Lab to Display QR</h6></li>
                                <% if (typeof navLabs !== 'undefined' && navLabs.length > 0) { %>
                                    <% navLabs.forEach(lab => { %>
                                        <li>
                                            <a class="dropdown-item" href="/qr/setup/<%= lab.id %>">
                                                <i class="bi bi-building me-1"></i><%= lab.name %>
                                            </a>
                                        </li>
                                    <% }) %>
                                <% } else { %>
                                    <li><span class="dropdown-item-text text-muted">No labs available</span></li>
                                <% } %>
                            </ul>
                        </li>
                    <% } %>
                    <% if (currentUser.role === 'admin') { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/labs/manage">
                                <i class="bi bi-gear me-1"></i>Manage Labs
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/users">
                                <i class="bi bi-people me-1"></i>Manage Users
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/sessions/report">
                                <i class="bi bi-graph-up me-1"></i>Reports
                            </a>
                        </li>
                    <% } %>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i>
                            <%= currentUser.name %>
                            <span class="badge bg-light text-dark ms-1"><%= currentUser.role %></span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text text-muted"><%= currentUser.email %></span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form action="/auth/logout" method="POST" class="d-inline">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                </ul>
            <% } else { %>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/auth/login">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Login
                        </a>
                    </li>
                </ul>
            <% } %>
        </div>
    </div>
</nav>
