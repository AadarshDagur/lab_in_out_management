<% if (typeof currentUser !=='undefined' && currentUser) { %>
    <aside class="app-sidebar">
        <div class="sidebar-user">
            <a href="/profile" class="sidebar-user-head text-decoration-none text-white">
                <div class="user-avatar-preview">
                    <% if (currentUser.profile_image) { %>
                        <img src="<%= currentUser.profile_image %>" alt="<%= currentUser.name %>">
                        <% } else { %>
                            <span>
                                <%= (currentUser.name || 'U' ).trim().charAt(0).toUpperCase() %>
                            </span>
                            <% } %>
                </div>
                <div class="d-flex flex-column">
                    <strong>
                        <%= currentUser.name %>
                    </strong>
                    <span>
                        <%= currentUser.email %>
                    </span>
                </div>
            </a>
            <span class="role-pill">
                <%= currentUser.activeRole || currentUser.role %>
            </span>
        </div>

        <nav class="sidebar-nav">
            <% const activeRole = currentUser.activeRole || currentUser.role; %>
            
            <% if (activeRole === 'student') { %>
                <a class="nav-link <%= currentPath === '/dashboard' ? 'active' : '' %>" href="/dashboard">
                    <i class="bi bi-door-open-fill"></i>
                    <span>Available Labs</span>
                </a>
                <a class="nav-link <%= currentPath === '/sessions/history' ? 'active' : '' %>"
                    href="/sessions/history">
                    <i class="bi bi-clock-history"></i>
                    <span>My Visits</span>
                </a>
                <a class="nav-link <%= currentPath === '/sessions/violations' ? 'active' : '' %>"
                    href="/sessions/violations">
                    <i class="bi bi-shield-exclamation"></i>
                    <span>My Violations</span>
                </a>
            <% } %>

            <% if (activeRole === 'assistant') { %>
                <a class="nav-link <%= currentPath === '/dashboard' && (!activeSection || activeSection === 'live') ? 'active' : '' %>"
                    href="/dashboard?section=live">
                    <i class="bi bi-broadcast-pin"></i>
                    <span>Live Sessions</span>
                </a>
                <a class="nav-link <%= currentPath === '/labs' || currentPath.startsWith('/labs/') ? 'active' : '' %>"
                    href="/labs">
                    <i class="bi bi-door-open-fill"></i>
                    <span>Labs</span>
                </a>
                <a class="nav-link <%= currentPath === '/dashboard' && activeSection === 'directory' ? 'active' : '' %>"
                    href="/dashboard?section=directory">
                    <i class="bi bi-people-fill"></i>
                    <span>Student Directory</span>
                </a>
                <a class="nav-link <%= currentPath === '/dashboard' && activeSection === 'violations' ? 'active' : '' %>"
                    href="/dashboard?section=violations">
                    <i class="bi bi-shield-exclamation"></i>
                    <span>Violations Marked</span>
                </a>
                <% if (currentUser.can_view_statistics) { %>
                <a class="nav-link <%= currentPath === '/statistics' ? 'active' : '' %>"
                    href="/statistics">
                    <i class="bi bi-graph-up"></i>
                    <span>Statistics</span>
                </a>
                <% } %>
            <% } %>

            <% if (activeRole === 'admin') { %>
                <a class="nav-link <%= currentPath === '/labs/manage' ? 'active' : '' %>"
                    href="/labs/manage">
                    <i class="bi bi-sliders"></i>
                    <span>Manage Labs</span>
                </a>
                <a class="nav-link <%= currentPath === '/users' ? 'active' : '' %>"
                    href="/users">
                    <i class="bi bi-people-fill"></i>
                    <span>Manage Users</span>
                </a>
                <a class="nav-link <%= currentPath === '/admin/violation-requests' ? 'active' : '' %>"
                    href="/admin/violation-requests">
                    <i class="bi bi-envelope-open-fill"></i>
                    <span>Pending Requests</span>
                    <% if (typeof pendingViolationRequests !== 'undefined' && pendingViolationRequests > 0) { %>
                        <span class="badge bg-danger ms-auto rounded-pill"><%= pendingViolationRequests %></span>
                    <% } %>
                </a>
                <a class="nav-link <%= currentPath === '/admin/directory' ? 'active' : '' %>"
                    href="/admin/directory">
                    <i class="bi bi-person-lines-fill"></i>
                    <span>Student Directory</span>
                </a>
                <a class="nav-link <%= currentPath === '/statistics' ? 'active' : '' %>"
                    href="/statistics">
                    <i class="bi bi-graph-up"></i>
                    <span>Statistics</span>
                </a>
                <a class="nav-link <%= currentPath === '/admin/logs' ? 'active' : '' %>"
                    href="/admin/logs">
                    <i class="bi bi-file-earmark-text-fill"></i>
                    <span>Audit Logs</span>
                </a>
                <a class="nav-link <%= currentPath === '/admin/settings' ? 'active' : '' %>"
                    href="/admin/settings">
                    <i class="bi bi-gear-fill"></i>
                    <span>Settings</span>
                </a>
            <% } %>
        </nav>

        <div class="mt-auto">
            <% if (currentUser.role === 'student+assistant') { %>
                <form action="/auth/switch-role" method="POST" class="mb-2 px-3">
                    <button type="submit" class="btn btn-warning w-100 btn-sm text-dark fw-bold">
                        <i class="bi bi-arrow-left-right me-1"></i> Switch to <%= activeRole === 'student' ? 'Assistant' : 'Student' %>
                    </button>
                </form>
            <% } %>
            <form action="/auth/logout" method="POST" class="px-3 pb-3">
                <button type="submit" class="btn btn-outline-light w-100 nav-logout">Logout</button>
            </form>
        </div>
    </aside>
    <% } else { %>
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container">
                <div class="ms-auto">
                    <a class="btn btn-outline-light btn-sm nav-logout" href="/auth/login">Login</a>
                </div>
            </div>
        </nav>
        <% } %>
